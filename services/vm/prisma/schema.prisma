generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum VmStatus {
  PENDING
  RUNNING
  STOPPED
  SUSPENDED
  ERROR
  DELETED
}

model Plan {
  id          String   @id @default(uuid())
  name        String   @unique
  maxVms      Int      @default(3)
  cpu         Int
  ramMb       Int
  diskGb      Int
  priceMonthly Float
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  virtualMachines VirtualMachine[]

  @@map("plans")
}

model VirtualMachine {
  id            String   @id @default(uuid())
  name          String
  oneVmId       Int?
  status        VmStatus @default(PENDING)
  cpu           Int
  ramMb         Int
  diskGb        Int
  ipAddress     String?
  osTemplate    String
  userId        String
  planId        String?
  plan          Plan?    @relation(fields: [planId], references: [id])
  sshHost       String?
  sshPort       Int?     @default(22)
  sshUsername   String?  @default("root")
  sshPrivateKeyEncrypted String?
  stoppedAt     DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([userId, name])
  @@map("virtual_machines")
}

model UserQuota {
  id        String @id @default(uuid())
  userId    String @unique
  maxVms    Int    @default(3)
  maxCpu    Int    @default(4)
  maxRamMb  Int    @default(4096)
  maxDiskGb Int    @default(50)

  @@map("user_quotas")
}
