{
  "name": "cloudvm",
  "version": "1.0.0",
  "private": true,
  "description": "CloudVM — Cloud Virtual Machine Management Platform",
  "scripts": {
    "dev": "docker-compose up -d",
    "dev:frontend": "cd frontend && npm run dev",
    "dev:gateway": "cd services/gateway && npm run start:dev",
    "dev:auth": "cd services/auth && npm run start:dev",
    "dev:user": "cd services/user && npm run start:dev",
    "dev:vm": "cd services/vm && npm run start:dev",
    "dev:payment": "cd services/payment && npm run start:dev",
    "build": "docker-compose build",
    "start": "docker-compose up",
    "stop": "docker-compose down",
    "db:migrate": "cd services/auth && npx prisma migrate dev",
    "db:seed": "cd services/auth && npx prisma db seed"
  },
  "dependencies": {
    "dotenv": "^17.3.1"
  }
}
