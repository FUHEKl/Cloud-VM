generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Payment {
  id        String   @id @default(uuid())
  userId    String
  amount    Float
  currency  String   @default("TND")
  status    String   @default("pending")
  method    String?
  createdAt DateTime @default(now())

  @@map("payments")
}