@startuml
node "User Browser" as Browser
node "Application Host" as AppHost {
  component "Frontend (Next.js)"
  component "Gateway (NestJS)"
  component "Auth/User/VM Services"
  component "Worker (Python)"
}
database "Relational DB" as DB
node "OpenNebula Infrastructure" as Infra

Browser --> AppHost
AppHost --> DB
AppHost --> Infra
@enduml
