# Database config
DATABASE_URL=postgresql://cloudvm:change_me@localhost:5434/cloudvm
POSTGRES_USER=cloudvm
POSTGRES_PASSWORD=change_me
POSTGRES_DB=cloudvm

# Split DB mode (active architecture)
AUTH_DATABASE_URL=postgresql://cloudvm:change_me@postgres:5432/cloudvm_auth
USER_DATABASE_URL=postgresql://cloudvm:change_me@postgres:5432/cloudvm_user
VM_DATABASE_URL=postgresql://cloudvm:change_me@postgres:5432/cloudvm_vm
PAYMENT_DATABASE_URL=postgresql://cloudvm:change_me@postgres:5432/cloudvm_payment
AI_DATABASE_URL=postgresql://cloudvm:change_me@postgres:5432/cloudvm_ai

# Single source of truth for managed plans (used by user + payment services)
PLAN_CATALOG_JSON={"student":{"amountDt":29,"rank":1,"vmHoursMonthly":60,"quota":{"maxVms":2,"maxCpu":2,"maxRamMb":4096,"maxDiskGb":40}},"pro":{"amountDt":79,"rank":2,"vmHoursMonthly":220,"quota":{"maxVms":6,"maxCpu":8,"maxRamMb":16384,"maxDiskGb":120}},"enterprise":{"amountDt":199,"rank":3,"vmHoursMonthly":900,"quota":{"maxVms":20,"maxCpu":32,"maxRamMb":65536,"maxDiskGb":400}}}

# VM SSH private key encryption secret (required)
VM_SSH_KEY_SECRET=replace_with_a_long_random_secret
INTER_SERVICE_SYNC_TOKEN=replace_with_a_long_random_secret

# JWT
JWT_SECRET=replace_with_a_long_random_secret
JWT_REFRESH_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
# Cookie security policy: false (local HTTP), true (force HTTPS), auto (detect by request/proxy)
AUTH_COOKIE_SECURE=false

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=replace_with_redis_password

# NATS - Credentials Required
NATS_USER=cloudvm_nats
NATS_PASSWORD=replace_with_nats_password
NATS_URL=nats://$NATS_USER:$NATS_PASSWORD@localhost:4222

# Edge proxy token (required to prevent bypassing the public edge)
EDGE_PROXY_TOKEN=replace_with_edge_proxy_token

# OpenNebula
ONE_XMLRPC=http://your-opennebula-host:2633/RPC2
ONE_USERNAME=oneadmin
ONE_PASSWORD=replace_with_opennebula_password
ONE_IP_OFFSET=0

# HTTPS / CORS
CORS_ORIGIN=http://localhost:3000,http://localhost

# Frontend public URLs (used at Next.js BUILD time)
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_VM_WS_URL=http://localhost:3001

# AI/LLM
AI_PROVIDER=ollama
