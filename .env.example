# ── Database ──────────────────────────────────────────
DATABASE_URL=postgresql://cloudvm:cloudvm_secret@localhost:5432/cloudvm
POSTGRES_USER=cloudvm
POSTGRES_PASSWORD=cloudvm_secret
POSTGRES_DB=cloudvm

# ── JWT ───────────────────────────────────────────────
JWT_SECRET=super-secret-jwt-key-change-in-production
JWT_REFRESH_SECRET=super-secret-refresh-key-change-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
AUTH_COOKIE_SECURE=auto
# SECURITY: in production, JWT_* secrets must be >= 64 chars
# and not default placeholders (auth service enforces this at startup).
# SECURITY: all Nest services validate both JWT_SECRET and JWT_REFRESH_SECRET at startup.
# AUTH_COOKIE_SECURE:
# - false => allow cookies on plain http://localhost (dev)
# - true  => force Secure cookies (HTTPS only)
# - auto  => secure only when request/proxy is HTTPS

# ── Redis ─────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# ── NATS ──────────────────────────────────────────────
NATS_URL=nats://localhost:4222

# ── OpenNebula ────────────────────────────────────────
ONE_XMLRPC=http://your-opennebula-host:2633/RPC2
ONE_USERNAME=oneadmin
ONE_PASSWORD=your-opennebula-password
# SECURITY: worker exits on startup if ONE_* credentials are missing or ONE_XMLRPC is invalid.

# Optional: SSH bastion for terminal connectivity when VM private IPs
# (e.g., 10.x.x.x) are not directly reachable from Docker containers.
# Usually this is your OpenNebula frontend host.
TERMINAL_SSH_BASTION_HOST=
TERMINAL_SSH_BASTION_PORT=22
TERMINAL_SSH_BASTION_USERNAME=
TERMINAL_SSH_BASTION_PASSWORD=
# Multiline key can be provided with literal \n escapes.
TERMINAL_SSH_BASTION_PRIVATE_KEY=
# Default VM password fallback used when terminal key auth fails for cloudvm.
TERMINAL_DEFAULT_VM_PASSWORD=cloudvm123
# SECURITY: password fallback should be disabled in production.
# If unset, runtime default is false in production and true in development.
TERMINAL_ALLOW_PASSWORD_FALLBACK=false
# Dangerous terminal command handling mode:
# - block: reject matched submitted commands (default)
# - audit: allow but log detections
TERMINAL_DANGEROUS_INPUT_MODE=block
TERMINAL_DANGEROUS_INPUT_MAX_VIOLATIONS=3
# WebSocket handshake rate limiting for terminal namespace at gateway edge.
TERMINAL_WS_RATE_LIMIT_PER_MINUTE=30
TERMINAL_WS_RATE_LIMIT_WINDOW_SECONDS=60
# open = allow WS connections if Redis is down (availability priority)
# closed = block WS connections if Redis is down (security priority)
WS_RATELIMIT_FAIL_BEHAVIOR=open

# ── Services Ports ────────────────────────────────────
GATEWAY_PORT=3001
AUTH_PORT=3002
USER_PORT=3003
VM_PORT=3004
PAYMENT_PORT=3005
AI_PORT=3006
FRONTEND_PORT=3000

# ── AI/LLM ─────────────────────────────────────────
AI_PROVIDER=ollama
AI_FALLBACK_ENABLED=true
AI_RATE_LIMIT_PER_MIN=20
AI_ACTION_CONFIRM_SECRET=
VM_SERVICE_URL=http://localhost:3004
USER_SERVICE_URL=http://localhost:3003
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mistral
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct:free

# ── Security hardening ────────────────────────────────
AUTH_LOCK_MAX_ATTEMPTS=5
AUTH_LOCK_WINDOW_MINUTES=15
AUTH_LOCK_PROGRESSIVE_MULTIPLIER=1
AUTH_LOCK_MAX_MINUTES=60
AUTH_CAPTCHA_ENABLED=false
AUTH_CAPTCHA_FAIL_THRESHOLD=3
AUTH_CAPTCHA_SHARED_SECRET=
AUTH_ANOMALY_MODE=log
AUTH_ANOMALY_RISK_THRESHOLD=70
AUTH_LOGIN_CONTEXT_TTL_SECONDS=7776000
# OpenNebula credentials (ONE_USERNAME/ONE_PASSWORD) must be passed
# only to the worker service (least privilege).

# ── Edge proxy verification ─────────────────────────
# SECURITY: change this token in production and keep it secret.
EDGE_PROXY_TOKEN=edge-local-dev-token-change-me
# Stripe redirect base URL for checkout success/cancel callbacks.
# Local default uses frontend dev server over HTTP.
PUBLIC_APP_ORIGIN=http://localhost:3000

# ── Stripe payments ─────────────────────────────────
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_TND_TO_USD_RATE=0.32

# ── Worker SSH key injection policy ───────────────────
# SECURITY: keep disabled for strict per-user VM SSH isolation.
INJECT_EXTRA_SSH_KEYS=false
EXTRA_SSH_KEYS_FILE=/app/extra_ssh_keys.txt
